# Validate commit message format: [#N] - verbo infinitivo ...
# Where N is a GitHub issue number (e.g. [#73])
COMMIT_MSG=$(cat "$1")
if ! echo "$COMMIT_MSG" | grep -qE '^\[#[0-9]+\] - .+'; then
  echo ""
  echo "  ⚠️  ERROR: Invalid commit message format!"
  echo ""
  echo "  Expected format: [#N] - verbo infinitivo ..."
  echo "  Example:         [#73] - Añadir Prettier a lint-staged"
  echo ""
  exit 1
fi
