# ============================================================
# .dockerignore — Exclude unnecessary files from Docker build
# ============================================================

# Dependencies
node_modules
.pnp
.pnp.js
.yarn/

# Next.js build output
.next
out

# Version control
.git
.gitignore
.gitattributes

# IDE & editor
.vscode
.idea
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Test coverage
coverage

# Docker files (prevent recursive copy)
Dockerfile
docker-compose.yml
.dockerignore

# Documentation
README.md
plans

# Misc
*.md
